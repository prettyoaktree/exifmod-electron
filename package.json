{
  "name": "exifmod-electron",
  "version": "1.7.3",
  "description": "EXIF metadata editor with presets (Electron)",
  "license": "MIT",
  "homepage": "https://github.com/prettyoaktree/exifmod#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/prettyoaktree/exifmod.git"
  },
  "bugs": {
    "url": "https://github.com/prettyoaktree/exifmod/issues"
  },
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -p tsconfig.node.json --noEmit && electron-vite build && electron-builder",
    "release:github": "tsc -p tsconfig.node.json --noEmit && electron-vite build && electron-builder --publish always",
    "build:vite": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run && node scripts/check-locale-keys.mjs",
    "test:watch": "vitest",
    "check:locales": "node scripts/check-locale-keys.mjs",
    "postinstall": "echo ok"
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "i18next": "^26.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "publish": {
      "provider": "github",
      "owner": "prettyoaktree",
      "repo": "exifmod",
      "releaseType": "release"
    },
    "appId": "dev.ay.exifmod",
    "productName": "EXIFmod",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      },
      {
        "from": "extras/lightroom-classic-exifmod-open/EXIFmodOpen.lrplugin",
        "to": "EXIFmodOpen.lrplugin"
      },
      {
        "from": "resources/default-presets",
        "to": "default-presets"
      }
    ],
    "afterSign": "./scripts/afterSign.mjs",
    "mac": {
      "category": "public.app-category.photography",
      "artifactName": "${productName}-${version}.${ext}",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false
    },
    "win": {
      "artifactName": "${productName}-${version}.${ext}",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "perMachine": false,
      "artifactName": "${productName}-${version}-setup.${ext}",
      "deleteAppDataOnUninstall": false,
      "runAfterFinish": true
    },
    "fileAssociations": [
      {
        "ext": [
          "jpg",
          "jpeg",
          "tif",
          "tiff"
        ],
        "name": "Image",
        "role": "Editor"
      }
    ]
  }
}
