{
  "name": "exifmod-electron",
  "version": "1.0.0",
  "description": "EXIF metadata editor with presets (Electron)",
  "main": "out/main/index.js",
  "type": "module",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "tsc -p tsconfig.node.json --noEmit && electron-vite build && electron-builder",
    "build:vite": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "echo ok"
  },
  "dependencies": {
    "i18next": "^26.0.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^17.0.2",
    "sql.js": "^1.12.0"
  },
  "devDependencies": {
    "@electron/notarize": "^2.5.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^34.0.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "typescript": "^5.7.2",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  },
  "build": {
    "appId": "dev.ay.exifmod",
    "productName": "EXIFmod",
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*"
    ],
    "icon": "build/icon.png",
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      },
      {
        "from": "node_modules/sql.js/dist/sql-wasm.wasm",
        "to": "sql-wasm.wasm"
      }
    ],
    "afterSign": "./scripts/afterSign.mjs",
    "mac": {
      "category": "public.app-category.photography",
      "target": [
        "dmg"
      ],
      "hardenedRuntime": true,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "notarize": false
    },
    "fileAssociations": [
      {
        "ext": [
          "jpg",
          "jpeg",
          "tif",
          "tiff"
        ],
        "name": "Image",
        "role": "Editor"
      }
    ]
  }
}
